# Server
SERVER__PORT=3000
SERVER__HOST=0.0.0.0

# Redis
REDIS__URL=redis://127.0.0.1:6379
REDIS__TTL_SECONDS=3600

# Security
# IMPORTANT: Must be at least 32 characters. Generate with: openssl rand -base64 32
SECURITY__FAIL_OPEN=false
SECURITY__ENCRYPTION_KEY=CHANGE_ME_TO_32_CHARS_MINIMUM!!!!

# Rate Limiting
RATE_LIMIT__REQUESTS_PER_SECOND=20
RATE_LIMIT__BURST_SIZE=10
RATE_LIMIT__TRUST_PROXY=false

# Observability
RUST_LOG=eidolon=info,tower_http=warn
LOGGING__FORMAT=json

# NLP (must exist as local files)
NLP__MODEL_PATH=assets/bert-ner-quantized.onnx
NLP__TOKENIZER_PATH=assets/tokenizer.json

# Token Limit (0 = unlimited)
LIMITS__MAX_PROMPT_TOKENS=0

# Shield Model (optional — comment out to use regex-only shield)
# SHIELD__MODEL_PATH=assets/deberta-v3-base-prompt-injection.onnx
# SHIELD__TOKENIZER_PATH=assets/shield-tokenizer.json

# Ollama
OLLAMA__BASE_URL=http://localhost:11434
